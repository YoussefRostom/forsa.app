rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // Helpers
    // =========================
    function isAuthed() {
      return request.auth != null;
    }

    // Admin access: support both the legacy `/admins/{uid}` allowlist and the live `users/{uid}.role == 'admin'` model.
    function isAdmin() {
      return isAuthed() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
          )
        )
      );
    }
    
    function isUserAdminByUid(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && (
          get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(uid)).data.role == 'Admin' ||
          get(/databases/$(database)/documents/users/$(uid)).data.role == 'ADMIN'
        );
    }

    function userRole() {
      return isAuthed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasNormalizedRole(expectedRole) {
      return isAuthed()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          (expectedRole == 'admin' && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
          )) ||
          (expectedRole == 'academy' && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'academy' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Academy' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ACADEMY'
          )) ||
          (expectedRole == 'clinic' && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Clinic' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'CLINIC'
          )) ||
          (expectedRole == 'player' && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'player' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Player' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'PLAYER'
          )) ||
          (expectedRole == 'parent' && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Parent' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'PARENT'
          )) ||
          (expectedRole == 'agent' && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Agent' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'AGENT'
          ))
        );
    }

    function hasRole(role) {
      return hasNormalizedRole(role);
    }

    function isConversationParticipant(conversationId) {
      return isAuthed()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participant1Id == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participant2Id == request.auth.uid ||
          (
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.keys().hasAny(['participants']) &&
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list &&
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants.hasAny([request.auth.uid])
          ) ||
          (
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.keys().hasAny(['participantIds']) &&
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds is list &&
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid])
          ) ||
          (
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.keys().hasAny(['members']) &&
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.members is list &&
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.members.hasAny([request.auth.uid])
          )
        );
    }

    function isBookingCustomer(data) {
      return isAuthed() && (
        data.playerId == request.auth.uid ||
        data.parentId == request.auth.uid ||
        data.userId == request.auth.uid ||
        data.academyId == request.auth.uid
      );
    }

    function isBookingProvider(data) {
      return isAuthed() && data.providerId == request.auth.uid;
    }

    function bookingCoreFieldsUnchanged() {
      return request.resource.data.playerId == resource.data.playerId &&
        request.resource.data.parentId == resource.data.parentId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.academyId == resource.data.academyId &&
        request.resource.data.providerId == resource.data.providerId &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function hasValidLocationsField(data) {
      return !data.keys().hasAny(['locations']) ||
        (data.locations is list && data.locations.size() <= 20);
    }

    function bookingProviderExists(data) {
      return data.providerId is string && (
        (data.type == 'academy' && exists(/databases/$(database)/documents/academies/$(data.providerId))) ||
        (data.type == 'clinic' && exists(/databases/$(database)/documents/clinics/$(data.providerId)))
      );
    }

    function hasValidBookingCreateData(data) {
      return data['providerId'] != null
        && (data['type'] == 'academy' || data['type'] == 'clinic')
        && data['status'] == 'pending'
        && bookingProviderExists(data)
        && (!data.keys().hasAny(['price']) || data['price'] >= 0)
        && (!data.keys().hasAny(['city']) || data['city'] != null)
        && (!data.keys().hasAny(['name']) || data['name'] != null)
        && (!data.keys().hasAny(['service']) || data['service'] != null)
        && (!data.keys().hasAny(['doctor']) || data['doctor'] != null);
    }

    function bookingAfter(bookingId) {
      return getAfter(/databases/$(database)/documents/bookings/$(bookingId)).data;
    }

    function notificationDataField(field) {
      return request.resource.data.keys().hasAny(['data']) && request.resource.data.data is map && request.resource.data.data.keys().hasAny([field]);
    }

    function notificationBookingRecipientAllowed() {
      return notificationDataField('bookingId')
        && request.resource.data.data.bookingId is string
        && exists(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId))
        && (
          get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data.providerId == request.resource.data.userId ||
          get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data.playerId == request.resource.data.userId ||
          get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data.parentId == request.resource.data.userId ||
          get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data.userId == request.resource.data.userId ||
          get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data.academyId == request.resource.data.userId ||
          isUserAdminByUid(request.resource.data.userId)
        )
        && (
          isBookingCustomer(get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data) ||
          isBookingProvider(get(/databases/$(database)/documents/bookings/$(request.resource.data.data.bookingId)).data) ||
          isAdmin()
        );
    }

    function notificationCheckInRecipientAllowed() {
      return notificationDataField('checkInId')
        && request.resource.data.data.checkInId is string
        && exists(/databases/$(database)/documents/checkins/$(request.resource.data.data.checkInId))
        && (
          get(/databases/$(database)/documents/checkins/$(request.resource.data.data.checkInId)).data.userId == request.resource.data.userId ||
          get(/databases/$(database)/documents/checkins/$(request.resource.data.data.checkInId)).data.playerId == request.resource.data.userId ||
          get(/databases/$(database)/documents/checkins/$(request.resource.data.data.checkInId)).data.parentId == request.resource.data.userId ||
          get(/databases/$(database)/documents/checkins/$(request.resource.data.data.checkInId)).data.locationId == request.resource.data.userId ||
          isUserAdminByUid(request.resource.data.userId)
        );
    }

    function notificationReportRecipientAllowed() {
      return notificationDataField('reportId')
        && request.resource.data.data.reportId is string
        && exists(/databases/$(database)/documents/reports/$(request.resource.data.data.reportId))
        && (
          get(/databases/$(database)/documents/reports/$(request.resource.data.data.reportId)).data.reporterId == request.resource.data.userId ||
          isUserAdminByUid(request.resource.data.userId)
        );
    }

    function notificationConversationRecipientAllowed() {
      return notificationDataField('conversationId')
        && request.resource.data.data.conversationId is string
        && exists(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId))
        && (
          get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participant1Id == request.resource.data.userId ||
          get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participant2Id == request.resource.data.userId ||
          (
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.keys().hasAny(['participants']) &&
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participants is list &&
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participants.hasAny([request.resource.data.userId])
          ) ||
          (
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.keys().hasAny(['participantIds']) &&
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participantIds is list &&
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.participantIds.hasAny([request.resource.data.userId])
          ) ||
          (
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.keys().hasAny(['members']) &&
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.members is list &&
            get(/databases/$(database)/documents/conversations/$(request.resource.data.data.conversationId)).data.members.hasAny([request.resource.data.userId])
          ) ||
          isUserAdminByUid(request.resource.data.userId)
        )
        && (
          isConversationParticipant(request.resource.data.data.conversationId) ||
          isAdmin()
        );
    }

    function canCreateNotification() {
      return isAdmin() || (
        isAuthed()
        && request.resource.data.userId is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.read == false
        && request.resource.data.keys().hasAll(['userId', 'title', 'body', 'type', 'read', 'createdAt', 'createdBy'])
        && request.resource.data.type in ['booking', 'checkin', 'report', 'info', 'system']
        && (
          request.resource.data.userId == request.auth.uid ||
          notificationBookingRecipientAllowed() ||
          notificationCheckInRecipientAllowed() ||
          notificationReportRecipientAllowed() ||
          notificationConversationRecipientAllowed()
        )
      );
    }

    function isBookingLinkedCheckIn(data) {
      return data.keys().hasAny(['meta'])
        && data.meta is map
        && data.meta.keys().hasAny(['linkedBookingId'])
        && data.meta.linkedBookingId is string
        && data.meta.linkedBookingId != null
        && data.meta.linkedBookingId != '';
    }

    function canCreateOwnBookingTransaction(transactionId) {
      return isAuthed()
        && request.resource.data.type == 'booking_commission'
        && request.resource.data.revenueSource == 'booking'
        && request.resource.data.bookingId is string
        && transactionId == 'booking_' + request.resource.data.bookingId
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && existsAfter(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId))
        && isBookingCustomer(bookingAfter(request.resource.data.bookingId))
        && bookingAfter(request.resource.data.bookingId).providerId == request.resource.data.providerId
        && bookingAfter(request.resource.data.bookingId).type == request.resource.data.providerRole
        && bookingAfter(request.resource.data.bookingId).status == request.resource.data.bookingStatus;
    }

    function canWriteOwnUserDoc(uid) {
      return isAuthed()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (
          request.resource.data.role == 'player' ||
          request.resource.data.role == 'parent' ||
          request.resource.data.role == 'academy' ||
          request.resource.data.role == 'clinic' ||
          request.resource.data.role == 'agent' ||
          request.resource.data.role == 'PLAYER' ||
          request.resource.data.role == 'PARENT' ||
          request.resource.data.role == 'ACADEMY' ||
          request.resource.data.role == 'CLINIC' ||
          request.resource.data.role == 'AGENT'
        )
        && hasValidLocationsField(request.resource.data);
    }

    function canWriteOwnRoleDoc(uid, role) {
      return isAuthed()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role == role
        && hasValidLocationsField(request.resource.data);
    }

    function canWriteOwnIndexDoc() {
      return isAuthed()
        && request.auth.token.email != null
        && request.resource.data.keys().hasOnly(['authEmail'])
        && request.resource.data.authEmail == request.auth.token.email;
    }

    function customerCanUpdateBooking() {
      return isBookingCustomer(resource.data)
        && resource.data.status != 'completed'
        && (
          // Customer can always cancel any non-completed booking (only status + updatedAt change)
          (
            request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt'])
          ) ||
          // Customer can accept (confirmed) or decline (cancelled) a time proposed by admin
          (
            (resource.data.status == 'new_time_proposed' || resource.data.status == 'timing_proposed') &&
            resource.data.proposedByAdmin == true &&
            (request.resource.data.status == 'confirmed' || request.resource.data.status == 'cancelled') &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt'])
          )
        );
    }

    function providerOrAdminCanManageBooking() {
      return resource.data.status != 'completed' && (
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'checkedInAt', 'lastCheckInId', 'lastCheckInAt', 'checkedInBy', 'attendanceStatus', 'source', 'updatedAt']) &&
          [
            'confirmed',
            'cancelled',
            'completed',
            'no_show',
            'refunded',
            'failed_payment'
          ].hasAny([request.resource.data.status])
        ) ||
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'date', 'time', 'preferredTime', 'proposedByAdmin', 'updatedAt']) &&
          (request.resource.data.status == 'new_time_proposed' || request.resource.data.status == 'timing_proposed') &&
          request.resource.data.proposedByAdmin == true
        )
      );
    }

    // =========================
    // 1) /admins - Admin only
    // =========================
    match /admins/{uid} {
      allow get, read, list, create, update, delete: if isAdmin();
    }

    // =========================
    // 2) /users - Read all auth, Write own only, Admin full access
    // =========================
    match /users/{uid} {
      // Reads & queries: any authenticated user (NO public access)
      allow get, read: if isAuthed();
      allow list: if isAuthed();

      // Writes: own doc only; admin can write all
      allow create: if isAdmin() || canWriteOwnUserDoc(uid);
      allow update: if isAdmin() || (
        canWriteOwnUserDoc(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid
      ); // Role + uid immutable for non-admins
      allow delete: if isAdmin();
    }

    // =========================
    // 3) Role collections - Read all auth, Write own only
    // /players, /parents, /academies, /clinics, /agents
    // =========================
    match /players/{uid} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();
      allow create: if isAdmin() || canWriteOwnRoleDoc(uid, 'player');
      allow update: if isAdmin() || (
        canWriteOwnRoleDoc(uid, 'player')
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isAuthed() && request.auth.uid == uid;
      allow read, write, list: if isAdmin();
    }

    match /parents/{uid} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();
      allow create: if isAdmin() || canWriteOwnRoleDoc(uid, 'parent');
      allow update: if isAdmin() || (
        canWriteOwnRoleDoc(uid, 'parent')
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isAuthed() && request.auth.uid == uid;
      allow read, write, list: if isAdmin();
    }

    match /academies/{uid} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();
      allow create: if isAdmin() || canWriteOwnRoleDoc(uid, 'academy');
      allow update: if isAdmin() || (
        canWriteOwnRoleDoc(uid, 'academy')
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isAuthed() && request.auth.uid == uid;
      allow read, write, list: if isAdmin();
    }

    match /clinics/{uid} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();
      allow create: if isAdmin() || canWriteOwnRoleDoc(uid, 'clinic');
      allow update: if isAdmin() || (
        canWriteOwnRoleDoc(uid, 'clinic')
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isAuthed() && request.auth.uid == uid;
      allow read, write, list: if isAdmin();
    }

    match /agents/{uid} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();
      allow create: if isAdmin() || canWriteOwnRoleDoc(uid, 'agent');
      allow update: if isAdmin() || (
        canWriteOwnRoleDoc(uid, 'agent')
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
      );
      allow delete: if isAuthed() && request.auth.uid == uid;
      allow read, write, list: if isAdmin();
    }

    // =========================
    // 4) /posts, /media - Read all (authed), Create/Update/Delete own only
    // MUST include list for feeds (queries)
    // MUST validate ownerId == auth.uid on create
    // MUST prevent ownerId changes on update
    // =========================
    match /posts/{postId} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();

      allow create: if isAuthed()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isAuthed()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isAuthed() && resource.data.ownerId == request.auth.uid;

      allow read, write, list: if isAdmin();
    }

    match /media/{mediaId} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();

      allow create: if isAuthed()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isAuthed()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isAuthed() && resource.data.ownerId == request.auth.uid;

      allow read, write, list: if isAdmin();
    }

    // =========================
    // 5) Role-based collections (queries require list)
    // /bookings, /conversations, /messages, /checkins, /notifications, /reports
    // =========================
    match /bookings/{bookingId} {
      // Only the booking customer, the provider, or an admin may read a booking.
      allow get, read: if isAuthed() && (
        isBookingCustomer(resource.data) ||
        isBookingProvider(resource.data) ||
        isAdmin()
      );

      // Create: requester must be booking for themselves and all customer identity fields,
      // if provided, must also point back to the signed-in user.
      allow create: if isAuthed()
        && request.resource.data.keys().hasAll(['providerId', 'type', 'status', 'createdAt'])
        && hasValidBookingCreateData(request.resource.data)
        && (!request.resource.data.keys().hasAny(['playerId']) || request.resource.data.playerId == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['parentId']) || request.resource.data.parentId == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['userId']) || request.resource.data.userId == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['academyId']) || request.resource.data.academyId == request.auth.uid)
        && (
          request.resource.data.playerId == request.auth.uid ||
          request.resource.data.parentId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.academyId == request.auth.uid ||
          isAdmin()
        );

      // Customers can only cancel or respond to a proposed time.
      // Providers have constrained status transitions.
      // Admin has full update override for operational support and moderation.
      allow update: if isAdmin()
        || (isBookingProvider(resource.data) && providerOrAdminCanManageBooking())
        || customerCanUpdateBooking();

      allow delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      // Allow authenticated users to check for existence (getDoc) when the
      // conversation does not yet exist, so getOrCreateConversation() can work.
      // For existing docs, restrict reads to participants or admin.
      allow get, read: if isAuthed() && (
        resource == null ||     // non-existent doc: allow the read attempt
        resource.data.participant1Id == request.auth.uid ||
        resource.data.participant2Id == request.auth.uid ||
        isAdmin()
      );

      // No blanket list access; queries must resolve only to conversations the caller participates in.

      // New conversations are restricted to admin-involved threads:
      // - any user can create a conversation with admin
      // - admin can create conversations with anyone
      allow create: if isAuthed()
        && request.resource.data.participant1Id is string
        && request.resource.data.participant2Id is string
        && request.resource.data.participant1Id != request.resource.data.participant2Id
        && (
          request.resource.data.participant1Id == request.auth.uid ||
          request.resource.data.participant2Id == request.auth.uid ||
          isAdmin()
        )
        && (
          isAdmin() ||
          isUserAdminByUid(request.resource.data.participant1Id) ||
          isUserAdminByUid(request.resource.data.participant2Id)
        );

      allow update, delete: if isAuthed() && (
        (
          (resource.data.participant1Id == request.auth.uid ||
            resource.data.participant2Id == request.auth.uid) &&
          request.resource.data.participant1Id == resource.data.participant1Id &&
          request.resource.data.participant2Id == resource.data.participant2Id
        ) ||
        isAdmin()
      );

      match /messages/{messageId} {
        allow get, read: if isAuthed() && (isConversationParticipant(conversationId) || isAdmin());
        allow list: if isAuthed() && (isConversationParticipant(conversationId) || isAdmin());

        allow create: if isAuthed()
          && request.resource.data.senderId == request.auth.uid
          && (isConversationParticipant(conversationId) || isAdmin());

        // Participants can only mark messages as read. Only admins can do broader edits,
        // and only the original sender can delete their own message.
        allow update: if isAdmin() || (
          isAuthed()
          && isConversationParticipant(conversationId)
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.content == resource.data.content
          && request.resource.data.mediaUrl == resource.data.mediaUrl
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.isRead == true
        );

        allow delete: if isAdmin() || (
          isAuthed() && resource.data.senderId == request.auth.uid
        );
      }
    }

    match /checkins/{checkinId} {
      allow get, read: if isAuthed() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.playerId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid
      );

      // Queries are limited to check-ins the caller owns, created, or administered.
      allow list: if isAuthed() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.playerId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.locationId == request.auth.uid
      );

      // Create: only academy/clinic, may be written as pending or completed depending on the scan flow
      allow create: if isAuthed()
        && (hasRole('academy') || hasRole('clinic'))
        && request.resource.data.createdBy == request.auth.uid
        && ['pending', 'completed'].hasAny([request.resource.data.status])
        && request.resource.data.keys().hasAll(['userId', 'createdBy', 'status', 'createdAt'])
        && !isBookingLinkedCheckIn(request.resource.data);

      // Update: ONLY admin can change status or other fields
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =========================
    // 13) /academy_programs - public for signed-in users + academy owner/admin
    // =========================
    match /academy_programs/{programId} {
      allow get, read: if isAuthed() && (
        isAdmin() ||
        resource.data.academyId == request.auth.uid ||
        true // authenticated users can read any program to view academies.
      );

      allow list: if isAuthed();

      allow create: if isAuthed() && (
        request.resource.data.academyId == request.auth.uid ||
        isAdmin()
      );

      allow update, delete: if isAuthed() && (
        resource.data.academyId == request.auth.uid ||
        isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow get, read: if isAuthed() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );

      allow create: if canCreateNotification();

      // Recipient can mark as read; admin can do anything.
      allow update: if isAdmin() || (
        isAuthed()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.read == true
      );

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow get, read: if isAuthed() && (
        resource.data.reporterId == request.auth.uid ||
        isAdmin()
      );

      allow list: if isAdmin(); // admin screens use queries

      allow create: if isAuthed()
        && request.resource.data.reporterId == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // =========================
    // 6) /checkInCodes - Check-in code reservation and lookup
    // Used during signup (player/parent) and for QR code scanning
    // =========================
    match /checkInCodes/{codeId} {
      // Read: Any authenticated user can read (needed for QR scanning/lookup)
      allow get, read: if isAuthed();
      allow list: if isAdmin();

      // Create: User can only reserve a code for themselves (uid must match auth.uid)
      // This ensures users can't create codes for other users
      allow create: if isAuthed()
        && request.resource.data.uid == request.auth.uid;

      // Update/Delete: Only admin (codes are immutable once created)
      allow update, delete: if isAdmin();
    }

    // =========================
    // 7) /settings - Read all auth, Write admin only
    // =========================
    match /settings/{settingId} {
      allow get, read: if isAuthed();
      allow list: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get, read, list, create, update, delete: if isAdmin();

      // Academy/clinic scanners create and update monetization transactions for their location
      allow get: if isAuthed() && (hasRole('academy') || hasRole('clinic'))
        && resource.data.providerId == request.auth.uid;

      // list needed for abuse-key duplicate check (where abuseKey == ...)
      allow list: if isAdmin() || (
        isAuthed() &&
        (hasRole('academy') || hasRole('clinic')) &&
        resource.data.providerId == request.auth.uid
      );

      allow create: if isAuthed() && (hasRole('academy') || hasRole('clinic'))
        && request.resource.data.providerId == request.auth.uid
        && request.resource.data.revenueSource == 'checkin'
        && !request.resource.data.keys().hasAny(['bookingId']);

      allow update: if isAuthed() && (hasRole('academy') || hasRole('clinic'))
        && resource.data.providerId == request.auth.uid
        && resource.data.revenueSource == 'checkin'
        && !resource.data.keys().hasAny(['bookingId']);
    }

    match /payouts/{payoutId} {
      allow get, read: if isAdmin() || (
        isAuthed() && resource.data.providerId == request.auth.uid && resource.data.recordType == 'summary'
      );
      allow delete: if isAdmin();

      // Admin full control
      allow list, create, update: if isAdmin();

      // Academy/clinic can list and upsert their own payout summary (refreshed after scan-triggered monetization)
      allow list: if isAdmin() || (
        isAuthed() &&
        (hasRole('academy') || hasRole('clinic')) &&
        resource.data.providerId == request.auth.uid
      );

      allow create: if isAuthed() && (hasRole('academy') || hasRole('clinic'))
        && request.resource.data.providerId == request.auth.uid;

      allow update: if isAuthed() && (hasRole('academy') || hasRole('clinic'))
        && resource.data.providerId == request.auth.uid;
    }

    match /admin_logs/{logId} {
      allow get, read, list, create, update, delete: if isAdmin();
    }

    match /admin_notes/{noteId} {
      allow get, read, list, create, update, delete: if isAdmin();
    }

    // =========================
    // 8) /emailIndex, /phoneIndex - Login lookup (public read for sign-in)
    // Maps email/phone to Firebase Auth identity so sign-in can resolve before auth.
    // =========================
    match /emailIndex/{docId} {
      allow get, read: if true;
      allow list: if false;
      allow create: if canWriteOwnIndexDoc();
      allow update: if isAdmin() || (
        canWriteOwnIndexDoc() && resource.data.authEmail == request.auth.token.email
      );
      allow delete: if isAdmin();
    }
    match /phoneIndex/{docId} {
      allow get, read: if true;
      allow list: if false;
      allow create: if canWriteOwnIndexDoc();
      allow update: if isAdmin() || (
        canWriteOwnIndexDoc() && resource.data.authEmail == request.auth.token.email
      );
      allow delete: if isAdmin();
    }

    // =========================
    // Default deny (NO public access)
    // =========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
